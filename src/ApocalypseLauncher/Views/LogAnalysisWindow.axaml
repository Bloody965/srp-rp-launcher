<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:ApocalypseLauncher.Views"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="600"
        x:Class="ApocalypseLauncher.Views.LogAnalysisWindow"
        x:DataType="views:LogAnalysisWindow"
        Title="AI Анализ Логов"
        Width="700" Height="600"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#1a1a1a"
        Foreground="White">

    <Window.Styles>
        <Style Selector="ScrollBar">
            <Setter Property="Background" Value="#2a2a2a"/>
        </Style>
        <Style Selector="ScrollBar:vertical">
            <Setter Property="Width" Value="12"/>
        </Style>
        <Style Selector="ScrollBar /template/ Thumb">
            <Setter Property="Background" Value="#404040"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="ScrollBar /template/ Thumb:pointerover">
            <Setter Property="Background" Value="#505050"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🤖 AI Анализ Логов"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#00d4ff"/>
            <TextBlock Text="Анализ выполнен с помощью Llama 3.3 70B"
                       FontSize="12"
                       Foreground="#888888"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Результат анализа -->
        <Border Grid.Row="1"
                Background="#2a2a2a"
                CornerRadius="8"
                Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding AnalysisResult}"
                           TextWrapping="Wrap"
                           FontSize="14"
                           LineHeight="22"
                           Foreground="White"/>
            </ScrollViewer>
        </Border>

        <!-- Кнопка закрытия -->
        <Button Grid.Row="2"
                Content="Закрыть"
                HorizontalAlignment="Center"
                Padding="40,12"
                Margin="0,20,0,0"
                Background="#00d4ff"
                Foreground="Black"
                FontWeight="SemiBold"
                FontSize="14"
                CornerRadius="6"
                Cursor="Hand"
                Click="CloseButton_Click">
            <Button.Styles>
                <Style Selector="Button:pointerover">
                    <Setter Property="Background" Value="#00b8e6"/>
                </Style>
            </Button.Styles>
        </Button>
    </Grid>
</Window>
