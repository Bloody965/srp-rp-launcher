<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ApocalypseLauncher.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="860"
        x:Class="ApocalypseLauncher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="SRP-RP Launcher"
        Width="1400" Height="860"
        MinWidth="1180" MinHeight="760"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="48"
        SystemDecorations="None">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid>
        <Image Source="/Assets/Images/background.png" Stretch="UniformToFill" Opacity="0.5"/>

        <Border>
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#A60A0806" Offset="0"/>
                    <GradientStop Color="#98120F0C" Offset="0.5"/>
                    <GradientStop Color="#B8080706" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Border IsHitTestVisible="False">
            <Border.Background>
                <RadialGradientBrush Center="15%,14%" RadiusX="54%" RadiusY="54%">
                    <GradientStop Color="#2EC6683F" Offset="0"/>
                    <GradientStop Color="#08C6683F" Offset="0.5"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <Border IsHitTestVisible="False">
            <Border.Background>
                <RadialGradientBrush Center="86%,18%" RadiusX="40%" RadiusY="40%">
                    <GradientStop Color="#188F9F67" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <Grid RowDefinitions="Auto,*,Auto">
            <Border Grid.Row="0" Padding="22,14,22,14" Classes="chromePanel" Margin="20,18,20,0" CornerRadius="12" PointerPressed="TitleBar_PointerPressed">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                        <Border Width="56" Height="56" CornerRadius="16" Classes="logoShell">
                            <Border.Background>
                                <ImageBrush Source="/Assets/Images/logo.png" Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>

                        <StackPanel Spacing="3" VerticalAlignment="Center">
                            <TextBlock Text="POST-APOCALYPSE RESIDENT RP" Classes="kickerText"/>
                            <TextBlock Text="SRP-RP LAUNCHER" Classes="heroTitleSmall"/>
                            <TextBlock Text="Forge 1.20.1 • official launcher terminal" Classes="metaText"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="24,0,0,0">
                        <Button Width="42" Height="42" Classes="ghostButton" Click="MinimizeButton_Click">
                            <Path Width="14" Height="14" Stretch="Uniform" Fill="#F1E7CE" Data="M2,9 H12 V11 H2 Z"/>
                        </Button>
                        <Button Width="42" Height="42" Classes="ghostButton" Click="ToggleMaximizeButton_Click">
                            <Path Width="14" Height="14" Stretch="Uniform" Fill="#F1E7CE" Data="M2,2 H12 V12 H2 Z M4,4 V10 H10 V4 Z"/>
                        </Button>
                        <Button Width="42" Height="42" Classes="ghostButton" Click="CloseButton_Click">
                            <Path Width="14" Height="14" Stretch="Uniform" Fill="#F1E7CE" Data="M3.4,2 L7,5.6 L10.6,2 L12,3.4 L8.4,7 L12,10.6 L10.6,12 L7,8.4 L3.4,12 L2,10.6 L5.6,7 L2,3.4 Z"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <Grid Margin="30,22,30,26">
                    <Grid IsVisible="{Binding !IsLoggedIn}" MaxWidth="1340" HorizontalAlignment="Center">
                        <Grid ColumnDefinitions="1.08*,0.92*" ColumnSpacing="24">
                            <Border Grid.Column="0" Classes="heroPanel" Padding="28">
                                <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="18">
                                    <StackPanel Spacing="10">
                                        <Border Background="#22D3924D" BorderBrush="#55D3924D" BorderThickness="1" CornerRadius="999" Padding="12,6" HorizontalAlignment="Left">
                                            <TextBlock Text="POST-APOCALYPSE RESIDENT RP" Classes="microLabel"/>
                                        </Border>
                                        <TextBlock Text="SRP-RP ЭТО MINECRAFT RP-ПРОЕКТ, ГДЕ КАЖДЫЙ ВАЙП ЭТО НОВЫЙ СЮЖЕТ И НОВАЯ ИСТОРИЯ" Classes="heroTitle" MaxWidth="760"/>
                                        <TextBlock Text="SRP-RP создан, чтобы дарить игрокам незабываемый опыт игры и RP. Мы вкладываемся в каждую деталь и выстраиваем атмосферу так, будто это отдельная игра внутри Minecraft." Classes="bodyText" TextWrapping="Wrap" MaxWidth="620"/>
                                    </StackPanel>

                                    <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="14">
                                        <Border Grid.Column="0" Classes="metricCard" Padding="18">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="ФОРМАТ" Classes="microLabel"/>
                                                <TextBlock Text="Resident RP" Classes="metricValue"/>
                                                <TextBlock Text="Сезонный проект с лором, ролями, фракциями и новой историей каждого вайпа." Classes="captionText" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1" Classes="metricCard" Padding="18">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="КЛИЕНТ" Classes="microLabel"/>
                                                <TextBlock Text="Forge 1.20.1" Classes="metricValue"/>
                                                <TextBlock Text="Вход, установка, обновление и запуск игры через один терминал." Classes="captionText" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border Grid.Row="2" Classes="pillCard" Padding="20,16">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                                            <Border Width="84" Height="84" CornerRadius="22" Classes="logoShell">
                                                <Border.Background>
                                                    <ImageBrush Source="/Assets/Images/logo.png" Stretch="Uniform"/>
                                                </Border.Background>
                                            </Border>

                                            <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                                <TextBlock Text="ACCESS NODE" Classes="microLabel"/>
                                                <TextBlock Text="Система доступа готова к авторизации" FontSize="22" FontWeight="Bold"/>
                                                <TextBlock Text="Войдите в аккаунт, чтобы получить статус сервера, обновить клиент и сразу выйти в игру." Classes="captionText" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="14" VerticalAlignment="Bottom">
                                        <Border Grid.Column="0" Classes="metricCard" Padding="18">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="ОПЕРАЦИИ" Classes="microLabel"/>
                                                <TextBlock Text="Одна точка входа" FontSize="20" FontWeight="Bold"/>
                                                <TextBlock Text="Авторизация, проверка клиента, обновление лаунчера и запуск игры собраны в одной панели." Classes="captionText" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1" Classes="metricCard" Padding="18">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="СТИЛЬ" Classes="microLabel"/>
                                                <TextBlock Text="Палитра сайта" FontSize="20" FontWeight="Bold"/>
                                                <TextBlock Text="Используется тёплая post-apocalypse схема со скрина: янтарь, ржавчина, пыль и тёмное стекло." Classes="captionText" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Classes="formPanel" Padding="30" MinWidth="420" MaxWidth="520" HorizontalAlignment="Center">
                                <Grid>
                                    <StackPanel Spacing="22" IsVisible="{Binding !IsResettingPassword}">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="ЛИНИЯ ПРОПУСКА" Classes="microLabel"/>
                                            <TextBlock Text="Вход в контрольный узел" Classes="formTitle"/>
                                            <TextBlock Text="Авторизуйтесь, чтобы открыть терминал запуска. Если аккаунта ещё нет, его можно зарегистрировать прямо здесь." Classes="captionText" TextWrapping="Wrap" MaxWidth="430"/>
                                        </StackPanel>

                                        <StackPanel Spacing="10">
                                            <TextBlock Text="ИМЯ ИГРОКА" Classes="fieldLabel"/>
                                            <TextBox Text="{Binding Username}" Watermark="Введите ваше имя" Height="54" FontSize="15"/>
                                        </StackPanel>

                                        <StackPanel Spacing="10">
                                            <TextBlock Text="ПАРОЛЬ" Classes="fieldLabel"/>
                                            <TextBox Text="{Binding Password}" Watermark="Введите пароль" PasswordChar="●" Height="54" FontSize="15"/>
                                        </StackPanel>

                                        <Border Classes="errorCard" Padding="16,14" IsVisible="{Binding HasLoginError}">
                                            <StackPanel Spacing="10">
                                                <TextBlock Text="{Binding LoginErrorMessage}" Foreground="#E3B39C" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Center"/>

                                                <!-- Копируемый recovery code -->
                                                <TextBox Text="{Binding RecoveryCodeDisplay}"
                                                         IsReadOnly="True"
                                                         IsVisible="{Binding ShowRecoveryCode}"
                                                         FontSize="18"
                                                         FontWeight="Bold"
                                                         TextAlignment="Center"
                                                         Background="#15D3924D"
                                                         BorderBrush="#D3924D"
                                                         BorderThickness="2"
                                                         Padding="12,8"
                                                         SelectionBrush="#D3924D"
                                                         SelectionForegroundBrush="#080706"/>
                                            </StackPanel>
                                        </Border>

                                        <StackPanel Spacing="12">
                                            <Button Content="ВОЙТИ В УЗЕЛ" Command="{Binding LoginCommand}" Classes="primaryButton" Height="58" IsVisible="{Binding !IsRegistering}"/>
                                            <Button Content="СОЗДАТЬ АККАУНТ" Command="{Binding RegisterCommand}" Classes="primaryButton" Height="58" IsVisible="{Binding IsRegistering}"/>
                                        </StackPanel>

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                            <Button Grid.Column="0" Content="РЕГИСТРАЦИЯ" Command="{Binding ToggleRegisterCommand}" Classes="secondaryButton" Height="50" IsVisible="{Binding !IsRegistering}"/>
                                            <Button Grid.Column="0" Content="ВХОД" Command="{Binding ToggleRegisterCommand}" Classes="secondaryButton" Height="50" IsVisible="{Binding IsRegistering}"/>
                                            <Button Grid.Column="1" Content="СБРОС ПАРОЛЯ" Command="{Binding ResetPasswordCommand}" Classes="ghostButton" Height="50"/>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Spacing="22" IsVisible="{Binding IsResettingPassword}">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="ВОССТАНОВЛЕНИЕ ДОСТУПА" Classes="microLabel"/>
                                            <TextBlock Text="Сброс пароля" Classes="formTitle"/>
                                            <TextBlock Text="Введите имя пользователя и код восстановления, который вы получили при регистрации" Classes="captionText" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <StackPanel Spacing="10">
                                            <TextBlock Text="ИМЯ ПОЛЬЗОВАТЕЛЯ" Classes="fieldLabel"/>
                                            <TextBox Text="{Binding Username}" Watermark="Введите имя пользователя" Height="54" FontSize="15"/>
                                        </StackPanel>

                                        <StackPanel Spacing="10">
                                            <TextBlock Text="КОД ВОССТАНОВЛЕНИЯ" Classes="fieldLabel"/>
                                            <TextBox Text="{Binding RecoveryCode}" Watermark="Введите 16-значный код" Height="54" FontSize="15" MaxLength="16"/>
                                        </StackPanel>

                                        <StackPanel Spacing="10">
                                            <TextBlock Text="НОВЫЙ ПАРОЛЬ" Classes="fieldLabel"/>
                                            <TextBox Text="{Binding NewPassword}" Watermark="Введите новый пароль" PasswordChar="●" Height="54" FontSize="15"/>
                                        </StackPanel>

                                        <Border Classes="errorCard" Padding="16,14" IsVisible="{Binding HasLoginError}">
                                            <TextBlock Text="{Binding LoginErrorMessage}" Foreground="#E3B39C" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Center"/>
                                        </Border>

                                        <Button Content="СОХРАНИТЬ НОВЫЙ ПАРОЛЬ" Command="{Binding ConfirmResetPasswordCommand}" Classes="primaryButton" Height="58"/>
                                        <Button Content="НАЗАД КО ВХОДУ" Command="{Binding CancelResetCommand}" Classes="ghostButton" Height="48"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <Grid IsVisible="{Binding IsLoggedIn}" MaxWidth="1360" HorizontalAlignment="Center">
                        <Grid RowDefinitions="Auto,*" RowSpacing="20">
                            <!-- Навигация -->
                            <Border Grid.Row="0" Classes="heroPanel" Padding="20,16">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="20">
                                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                        <Button Command="{Binding ShowHomeTabCommand}" Classes="primaryButton" Height="44" Padding="20,0" IsVisible="{Binding CurrentTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Home}">
                                            <TextBlock Text="ГЛАВНАЯ" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                        </Button>
                                        <Button Command="{Binding ShowHomeTabCommand}" Classes="ghostButton" Height="44" Padding="20,0" IsVisible="{Binding CurrentTab, Converter={x:Static ObjectConverters.NotEqual}, ConverterParameter=Home}">
                                            <TextBlock Text="ГЛАВНАЯ" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                        </Button>

                                        <Button Command="{Binding ShowPersonalizationTabCommand}" Classes="primaryButton" Height="44" Padding="20,0" IsVisible="{Binding CurrentTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Personalization}">
                                            <TextBlock Text="ПЕРСОНАЛИЗАЦИЯ" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                        </Button>
                                        <Button Command="{Binding ShowPersonalizationTabCommand}" Classes="ghostButton" Height="44" Padding="20,0" IsVisible="{Binding CurrentTab, Converter={x:Static ObjectConverters.NotEqual}, ConverterParameter=Personalization}">
                                            <TextBlock Text="ПЕРСОНАЛИЗАЦИЯ" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                        </Button>

                                        <Button Command="{Binding ShowLogsTabCommand}" Classes="primaryButton" Height="44" Padding="20,0" IsVisible="{Binding CurrentTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Logs}">
                                            <TextBlock Text="ЛОГИ" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                        </Button>
                                        <Button Command="{Binding ShowLogsTabCommand}" Classes="ghostButton" Height="44" Padding="20,0" IsVisible="{Binding CurrentTab, Converter={x:Static ObjectConverters.NotEqual}, ConverterParameter=Logs}">
                                            <TextBlock Text="ЛОГИ" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                        </Button>

                                        <Button Command="{Binding ShowProfileTabCommand}" Classes="primaryButton" Height="44" Padding="20,0" IsVisible="{Binding CurrentTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Profile}">
                                            <TextBlock Text="ПРОФИЛЬ" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                        </Button>
                                        <Button Command="{Binding ShowProfileTabCommand}" Classes="ghostButton" Height="44" Padding="20,0" IsVisible="{Binding CurrentTab, Converter={x:Static ObjectConverters.NotEqual}, ConverterParameter=Profile}">
                                            <TextBlock Text="ПРОФИЛЬ" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Вкладка: Главная -->
                            <Grid Grid.Row="1" IsVisible="{Binding CurrentTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Home}" ColumnDefinitions="*,*" ColumnSpacing="18">
                                <Border Grid.Column="0" Classes="heroPanel" Padding="30">
                                    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="18">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="24">
                                            <Border Width="132" Height="132" CornerRadius="30" Classes="logoShell" HorizontalAlignment="Left">
                                                <Border.Background>
                                                    <ImageBrush Source="/Assets/Images/logo.png" Stretch="Uniform"/>
                                                </Border.Background>
                                            </Border>

                                            <StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Center" MaxWidth="420">
                                                <Border Background="#22D3924D" BorderBrush="#55D3924D" BorderThickness="1" CornerRadius="999" Padding="12,6" HorizontalAlignment="Left">
                                                    <TextBlock Text="POST-APOCALYPSE RESIDENT RP" Classes="microLabel"/>
                                                </Border>
                                                <TextBlock Text="ПРИВЕТСТВУЕМ, ВЫЖИВШИЙ" Classes="heroTitle"/>
                                                <TextBlock Text="Официальный лаунчер SRP-RP" Classes="sectionLead"/>
                                                <TextBlock Text="{Binding ModpackVersion}" Classes="versionBadge"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Grid.Row="1">
                                            <Border Classes="metricCard" Padding="18,16">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="СЕРВЕР" Classes="microLabel"/>
                                                    <TextBlock Text="{Binding ServerStatusText}" FontSize="22" FontWeight="Bold" TextWrapping="Wrap" Foreground="{Binding ServerStatusColor}"/>
                                                    <TextBlock Text="Статус площадки в реальном времени и готовность к входу." Classes="captionText" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Border Grid.Row="2" Classes="pillCard" Padding="22,20">
                                            <StackPanel Spacing="10" MaxWidth="540" HorizontalAlignment="Left">
                                                <TextBlock Text="О ПРОЕКТЕ" Classes="microLabel"/>
                                                <TextBlock Text="SRP-RP создан, чтобы дарить игрокам незабываемый опыт игры и RP. Мы вкладываемся в каждую деталь и выстраиваем атмосферу так, будто это отдельная игра внутри Minecraft." Classes="bodyText" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="14">
                                            <Button Grid.Column="0" Classes="linkButton" Click="OpenSiteButton_Click" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Height="138">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="22" VerticalAlignment="Center">
                                                    <StackPanel Grid.Column="0" Spacing="8" VerticalAlignment="Center" MaxWidth="245">
                                                        <TextBlock Text="ОФИЦИАЛЬНЫЙ САЙТ" Classes="microLabel"/>
                                                        <TextBlock Text="Сайт проекта" FontSize="21" FontWeight="Bold"/>
                                                        <TextBlock Text="Лор, новости, правила, быстрый старт и весь основной контент SRP-RP." Classes="captionText" TextWrapping="Wrap"/>
                                                    </StackPanel>

                                                    <Border Grid.Column="1" Width="46" Height="46" CornerRadius="14" VerticalAlignment="Center" Background="#1F1812" BorderBrush="#7A6245" BorderThickness="1.1">
                                                        <Path Width="16" Height="16"
                                                              Stretch="Uniform"
                                                              Fill="#E9D9B7"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Data="M4,4 H12 V6 H7.41 L13,11.59 L11.59,13 L6,7.41 V12 H4 Z"/>
                                                    </Border>
                                                </Grid>
                                            </Button>

                                            <Button Grid.Column="1" Classes="linkButton" Click="OpenDiscordButton_Click" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Height="138">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16" VerticalAlignment="Center">
                                                    <Border Width="74" Height="74" CornerRadius="18" VerticalAlignment="Center" Background="#221C16" BorderBrush="#7A6245" BorderThickness="1.1" Padding="10">
                                                        <Image Source="/Assets/Images/discord_no_bg.png" Stretch="Uniform"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center" MaxWidth="250">
                                                        <TextBlock Text="DISCORD КОМЬЮНИТИ" Classes="microLabel"/>
                                                        <TextBlock Text="Discord проекта" FontSize="21" FontWeight="Bold"/>
                                                        <TextBlock Text="Общение с игроками, помощь по сборке, анонсы и поддержка комьюнити." Classes="captionText" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Button>
                                        </Grid>

                                        <TextBlock Grid.Row="4" Text="{Binding AboutProjectText}" Classes="captionText" TextWrapping="Wrap"/>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Column="1" Spacing="18" MinWidth="420" HorizontalAlignment="Stretch">
                                    <Border Classes="formPanel" Padding="26">
                                        <StackPanel Spacing="14">
                                            <TextBlock Text="ЦЕНТР УПРАВЛЕНИЯ" Classes="microLabel"/>
                                            <TextBlock Text="Панель запуска" Classes="formTitle"/>
                                            <TextBlock Text="Главное действие вынесено наверх, а служебные операции собраны ниже в одном блоке." Classes="captionText" TextWrapping="Wrap"/>

                                            <Button Content="ОБНОВИТЬ ЛАУНЧЕР" Command="{Binding UpdateLauncherCommand}" IsVisible="{Binding HasLauncherUpdate}" Classes="launchButton" Height="76" FontSize="22"/>

                                            <Button Content="ИГРАТЬ" Command="{Binding LaunchCommand}" Classes="launchButton" Height="76" FontSize="24">
                                                <Button.IsVisible>
                                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                        <Binding Path="IsInstalled"/>
                                                        <Binding Path="!HasLauncherUpdate"/>
                                                    </MultiBinding>
                                                </Button.IsVisible>
                                            </Button>

                                            <Button Content="УСТАНОВИТЬ КЛИЕНТ" Command="{Binding InstallCommand}" IsVisible="{Binding !IsInstalled}" Classes="primaryButton" Height="58" FontSize="18"/>
                                            <Button Command="{Binding InstallCommand}" IsVisible="{Binding IsInstalled}" Classes="secondaryButton" Height="56" FontSize="16">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                    <Border Width="28" Height="28" CornerRadius="8" Background="#18D3924D" BorderBrush="#55D3924D" BorderThickness="1" VerticalAlignment="Center">
                                                        <Path Width="16"
                                                              Height="16"
                                                              Stretch="Uniform"
                                                              Fill="#F1E7CE"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Data="M4,3 H11 L14,6 V13 H4 Z M10.5,3 V6 H13.5 M6.5,9.5 L8.2,11.2 L11.6,7.8"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="ПРОВЕРИТЬ ФАЙЛЫ" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold"/>
                                                </Grid>
                                            </Button>
                                            <Button Click="ChooseFolderButton_Click" Classes="ghostButton" Height="54" FontSize="15">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                    <Border Width="28" Height="28" CornerRadius="8" Background="#10FFF2D8" BorderBrush="#557A6245" BorderThickness="1" VerticalAlignment="Center">
                                                        <Path Width="17"
                                                              Height="17"
                                                              Stretch="Uniform"
                                                              Fill="#F1E7CE"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Data="M2,5 H6 L7.4,6.4 H14 C14.6,6.4 15,6.8 15,7.4 V12.8 C15,13.4 14.6,13.8 14,13.8 H2.8 C2.2,13.8 1.8,13.4 1.8,12.8 V6 C1.8,5.4 2.2,5 2.8,5 Z"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="ВЫБРАТЬ ПАПКУ" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold"/>
                                                </Grid>
                                            </Button>
                                        </StackPanel>
                                    </Border>

                                    <Border Classes="statusPanel" Padding="24" IsVisible="{Binding StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <StackPanel Spacing="14">
                                            <TextBlock Text="ЖУРНАЛ СОСТОЯНИЯ" Classes="microLabel"/>
                                            <TextBlock Text="{Binding StatusMessage}" Classes="statusText" TextWrapping="Wrap"/>
                                            <ProgressBar Value="{Binding ProgressValue}" Maximum="100" Height="12" IsVisible="{Binding ProgressValue, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Classes="formPanel" Padding="26" IsVisible="{Binding IsInstalled}">
                                        <StackPanel Spacing="14">
                                            <TextBlock Text="СИСТЕМНЫЕ ПАРАМЕТРЫ" Classes="microLabel"/>
                                            <TextBlock Text="Оперативная память" Classes="formTitle" FontSize="20"/>
                                            <TextBlock Text="Подстройте доступную память под ваше железо. Для комфортной игры обычно хватает 4–8 GB." Classes="captionText" TextWrapping="Wrap"/>

                                            <StackPanel Spacing="8">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Column="0" Text="Выделено для игры" Classes="bodyText"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AllocatedRamText}" FontSize="18" FontWeight="Bold" Foreground="#D3924D"/>
                                                </Grid>
                                                <Slider Value="{Binding AllocatedRamGB}" Minimum="2" Maximum="16" TickFrequency="1" IsSnapToTickEnabled="True" Height="40"/>
                                                <TextBlock Text="Рекомендуемая зона: 4–8 GB" Classes="captionText"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Вкладка: Персонализация -->
                            <Grid Grid.Row="1" IsVisible="{Binding CurrentTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Personalization}">
                                <Border Classes="formPanel" Padding="30" MaxWidth="900" HorizontalAlignment="Center">
                                    <StackPanel Spacing="20">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="ПЕРСОНАЛИЗАЦИЯ" Classes="microLabel"/>
                                            <TextBlock Text="Скины и плащи" Classes="formTitle" FontSize="24"/>
                                            <TextBlock Text="Загрузите свой уникальный скин и плащ для персонажа в игре." Classes="bodyText" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="30">
                                            <Border Grid.Column="0" Width="280" Height="560" Background="#15FFF2D8" CornerRadius="8" BorderBrush="#557A6245" BorderThickness="1" Padding="20">
                                                <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Image Source="{Binding CurrentSkinPreview}" Stretch="None"/>
                                                </Viewbox>
                                            </Border>

                                            <StackPanel Grid.Column="1" Spacing="16" VerticalAlignment="Center" MaxWidth="400">
                                                <StackPanel Spacing="10">
                                                    <TextBlock Text="Модель персонажа" Classes="bodyText" FontWeight="SemiBold" FontSize="16"/>
                                                    <StackPanel Spacing="8">
                                                        <RadioButton IsChecked="{Binding IsClassicSkin}" Content="Steve (Classic)" FontSize="15"/>
                                                        <RadioButton IsChecked="{Binding IsSlimSkin}" Content="Alex (Slim)" FontSize="15"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <StackPanel Spacing="10" Margin="0,10,0,0">
                                                    <Button Command="{Binding UploadSkinCommand}" Classes="primaryButton" Height="50" FontSize="16">
                                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                            <Path Width="18" Height="18" Stretch="Uniform" Fill="#080706" Data="M12,4 L12,12 M8,8 L12,4 L16,8 M4,16 L20,16"/>
                                                            <TextBlock Grid.Column="1" Text="ЗАГРУЗИТЬ СКИН" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                        </Grid>
                                                    </Button>

                                                    <Button Command="{Binding UploadCapeCommand}" Classes="secondaryButton" Height="50" FontSize="16">
                                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                            <Path Width="18" Height="18" Stretch="Uniform" Fill="#F1E7CE" Data="M12,4 L12,12 M8,8 L12,4 L16,8 M4,16 L20,16"/>
                                                            <TextBlock Grid.Column="1" Text="ЗАГРУЗИТЬ ПЛАЩ" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                        </Grid>
                                                    </Button>

                                                    <Button Command="{Binding DeleteSkinCommand}" Classes="ghostButton" Height="46" FontSize="15">
                                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                            <Path Width="16" Height="16" Stretch="Uniform" Fill="#F1E7CE" Data="M6,2 L18,2 M8,2 L8,1 L16,1 L16,2 M10,7 L10,17 M14,7 L14,17 M4,4 L20,4 L19,20 L5,20 Z"/>
                                                            <TextBlock Grid.Column="1" Text="УДАЛИТЬ СКИН" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                        </Grid>
                                                    </Button>
                                                </StackPanel>

                                                <TextBlock Text="{Binding SkinStatus}" Classes="captionText" TextWrapping="Wrap" Margin="0,8,0,0" Foreground="#D3924D" FontSize="14"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Вкладка: Профиль -->
                            <Grid Grid.Row="1" IsVisible="{Binding CurrentTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Profile}">
                                <Border Classes="formPanel" Padding="30" MaxWidth="900" HorizontalAlignment="Center">
                                    <StackPanel Spacing="24">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="ПРОФИЛЬ" Classes="microLabel"/>
                                            <TextBlock Text="Информация об аккаунте" Classes="formTitle" FontSize="24"/>
                                            <TextBlock Text="Управление вашим профилем и статистикой игрока." Classes="bodyText" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <Border Classes="pillCard" Padding="24">
                                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="18">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="ИМЯ ПОЛЬЗОВАТЕЛЯ" Classes="microLabel"/>
                                                    <TextBlock Text="{Binding Username}" FontSize="22" FontWeight="Bold" Foreground="#D3924D"/>
                                                </StackPanel>

                                                <Border Grid.Row="1" Height="1" Background="#22D3924D"/>

                                                <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="20">
                                                    <StackPanel Grid.Column="0" Spacing="8">
                                                        <TextBlock Text="ВРЕМЯ В ИГРЕ" Classes="microLabel"/>
                                                        <TextBlock Text="{Binding PlayTimeFormatted}" FontSize="20" FontWeight="Bold"/>
                                                        <TextBlock Text="Суммарное игровое время персонажа в проекте." Classes="captionText" TextWrapping="Wrap"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Spacing="8">
                                                        <TextBlock Text="СТАТУС АККАУНТА" Classes="microLabel"/>
                                                        <TextBlock Text="Активен" FontSize="20" FontWeight="Bold" Foreground="#7BC96F"/>
                                                        <TextBlock Text="Ваш аккаунт подтвержден и готов к игре." Classes="captionText" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Grid>

                                                <Border Grid.Row="3" Height="1" Background="#22D3924D"/>
                                            </Grid>
                                        </Border>

                                        <Border Classes="pillCard" Padding="24">
                                            <StackPanel Spacing="16">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="ПЕРСОНАЛИЗАЦИЯ" Classes="microLabel"/>
                                                    <TextBlock Text="Настройки внешнего вида" FontSize="18" FontWeight="Bold"/>
                                                </StackPanel>

                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="20">
                                                    <Border Grid.Column="0" Width="128" Height="256" Background="#15FFF2D8" CornerRadius="8" BorderBrush="#557A6245" BorderThickness="1">
                                                        <Image Source="{Binding CurrentSkinPreview}" Stretch="Uniform" Width="120" Height="240"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1" Spacing="12" VerticalAlignment="Center">
                                                        <StackPanel Spacing="8">
                                                            <TextBlock Text="МОДЕЛЬ ПЕРСОНАЖА" Classes="microLabel"/>
                                                            <StackPanel Spacing="4">
                                                                <TextBlock Text="Steve (Classic)" FontSize="16" FontWeight="SemiBold" IsVisible="{Binding IsClassicSkin}"/>
                                                                <TextBlock Text="Alex (Slim)" FontSize="16" FontWeight="SemiBold" IsVisible="{Binding IsSlimSkin}"/>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <TextBlock Text="{Binding SkinStatus}" Classes="captionText" TextWrapping="Wrap" Foreground="#D3924D"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Button Command="{Binding LogoutCommand}" Classes="secondaryButton" Height="54" FontSize="16" HorizontalAlignment="Center" MinWidth="250">
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                <Path Width="18" Height="18" Stretch="Uniform" Fill="#F1E7CE" VerticalAlignment="Center"
                                                      Data="M17,7 L15.59,8.41 L18.17,11 L8,11 L8,13 L18.17,13 L15.59,15.59 L17,17 L22,12 Z M4,5 L12,5 L12,3 L4,3 C2.9,3 2,3.9 2,5 L2,19 C2,20.1 2.9,21 4,21 L12,21 L12,19 L4,19 Z"/>
                                                <TextBlock Grid.Column="1" Text="ВЫЙТИ" VerticalAlignment="Center" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            </Grid>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Вкладка: Логи -->
                            <Grid Grid.Row="1" IsVisible="{Binding CurrentTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Logs}">
                                <Border Classes="formPanel" Padding="30">
                                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="20">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="ЛОГИ ИГРЫ" Classes="microLabel"/>
                                            <TextBlock Text="Журнал событий Minecraft" Classes="formTitle" FontSize="24"/>
                                            <TextBlock Text="Просмотр логов игры и анализ ошибок с помощью AI." Classes="bodyText" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <Border Grid.Row="1" Classes="pillCard" Padding="20" Background="#0A0A0A" BorderBrush="#333333" BorderThickness="1">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                                <TextBox Text="{Binding GameLogs}"
                                                         IsReadOnly="True"
                                                         TextWrapping="Wrap"
                                                         FontFamily="Consolas,Courier New,monospace"
                                                         FontSize="12"
                                                         Background="Transparent"
                                                         Foreground="#E0E0E0"
                                                         BorderThickness="0"
                                                         AcceptsReturn="True"
                                                         MinHeight="400"/>
                                            </ScrollViewer>
                                        </Border>

                                        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                            <TextBlock Grid.Column="0" Text="{Binding LogStatus}" Classes="captionText" VerticalAlignment="Center"/>

                                            <Button Grid.Column="1" Command="{Binding RefreshLogsCommand}" Classes="ghostButton" Height="44" Padding="20,0">
                                                <TextBlock Text="ОБНОВИТЬ" FontWeight="SemiBold" FontSize="14"/>
                                            </Button>

                                            <Button Grid.Column="2" Command="{Binding AnalyzeLogsWithAICommand}" Classes="primaryButton" Height="44" Padding="20,0" IsEnabled="{Binding !IsAnalyzingLogs}">
                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10">
                                                    <Path Grid.Column="0" Width="16" Height="16" Stretch="Uniform" Fill="#0A0806" VerticalAlignment="Center"
                                                          Data="M12,2 C17.5,2 22,6.5 22,12 C22,17.5 17.5,22 12,22 C6.5,22 2,17.5 2,12 C2,6.5 6.5,2 12,2 M12,4 C7.6,4 4,7.6 4,12 C4,16.4 7.6,20 12,20 C16.4,20 20,16.4 20,12 C20,7.6 16.4,4 12,4 M12,6 L14,10 L18,10 L15,13 L16,17 L12,14 L8,17 L9,13 L6,10 L10,10 Z"/>
                                                    <TextBlock Grid.Column="1" Text="АНАЛИЗ AI" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Button>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </ScrollViewer>

            <Border Grid.Row="2" Padding="28,18" Classes="chromePanel" Margin="20,0,20,18" CornerRadius="12">
                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="18">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="SRP-RP Launcher" FontSize="13" FontWeight="Bold" Foreground="#D3924D"/>
                        <TextBlock Text="v1.0" Classes="captionText"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="Post-apocalypse web palette • Forge 1.20.1" Classes="captionText" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="2" Text="Field access for SRP-RP • 2026" Classes="captionText" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <Border IsVisible="{Binding IsGameRunning}" Background="#E0080706">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Padding="42" CornerRadius="18" Classes="overlayPanel" MinWidth="420" MaxWidth="520">
                <StackPanel Spacing="18">
                    <TextBlock Text="ИГРА УЖЕ В ПОЛЕ" Classes="overlayTitle" HorizontalAlignment="Center"/>
                    <TextBlock Text="Клиент уже запущен. Лаунчер можно свернуть или закрыть: игровая сессия продолжит работу отдельно." Classes="bodyText" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" MaxWidth="360"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
