<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ApocalypseLauncher.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="820"
        x:Class="ApocalypseLauncher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="SRP-RP Launcher"
        Width="1280" Height="820"
        MinWidth="1180" MinHeight="760"
        WindowStartupLocation="CenterScreen"
        CanResize="True">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid>
        <Image Source="/Assets/Images/background.png" Stretch="UniformToFill" Opacity="0.45"/>
        <Border Background="#070403" Opacity="0.35"/>

        <Border Opacity="0.18" IsHitTestVisible="False">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#ff5a00" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="0.28"/>
                    <GradientStop Color="#00000000" Offset="0.72"/>
                    <GradientStop Color="#ffb000" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Grid RowDefinitions="Auto,*,Auto">
            <Border Grid.Row="0" Padding="34,24,34,22" Classes="chromePanel">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="24">
                    <StackPanel Orientation="Horizontal" Spacing="18" VerticalAlignment="Center">
                        <Border Width="78" Height="78" CornerRadius="18" Classes="logoShell">
                            <Border.Background>
                                <ImageBrush Source="/Assets/Images/logo.png" Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>

                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="SRP-RP LAUNCHER" Classes="heroTitleSmall"/>
                            <TextBlock Text="Minecraft 1.20.1 Forge" Classes="metaText"/>
                            <TextBlock Text="Post-apocalypse roleplay experience" Classes="captionText"/>
                        </StackPanel>
                    </StackPanel>

                    <Grid Grid.Column="1" IsVisible="{Binding IsLoggedIn}">
                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="14">
                            <Border Grid.Column="0" Classes="profileCard" Padding="18,12">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="АККАУНТ" Classes="microLabel"/>

                                    <!-- Режим просмотра никнейма -->
                                    <Grid IsVisible="{Binding !IsEditingNickname}">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Text="{Binding Username}" FontSize="17" FontWeight="Bold" TextTrimming="CharacterEllipsis" MaxWidth="180" VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Content="✏" Command="{Binding EditNicknameCommand}" Classes="ghostButton" Width="32" Height="32" FontSize="14" Padding="0" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Grid>

                                    <!-- Режим редактирования никнейма -->
                                    <StackPanel Spacing="6" IsVisible="{Binding IsEditingNickname}">
                                        <TextBox Text="{Binding NewNickname}" Watermark="Новый никнейм" Height="36" FontSize="14" MaxWidth="200"/>
                                        <TextBlock Text="{Binding LoginErrorMessage}" Foreground="#ff6a4a" FontSize="11" TextWrapping="Wrap" IsVisible="{Binding HasLoginError}"/>
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                            <Button Grid.Column="0" Content="✓" Command="{Binding SaveNicknameCommand}" Classes="primaryButton" Height="32" FontSize="14" Padding="8,0"/>
                                            <Button Grid.Column="1" Content="✕" Command="{Binding CancelEditNicknameCommand}" Classes="ghostButton" Height="32" FontSize="14" Padding="8,0"/>
                                        </Grid>
                                    </StackPanel>

                                    <TextBlock Text="{Binding UserEmail}" Classes="captionText" TextTrimming="CharacterEllipsis" MaxWidth="220"/>
                                    <TextBlock Text="{Binding PlayTimeFormatted, StringFormat='🕐 {0}'}" Classes="captionText" Foreground="#ffb267"/>
                                </StackPanel>
                            </Border>

                            <Button Grid.Column="1" Content="ВЫЙТИ" Command="{Binding LogoutCommand}" Classes="secondaryButton" Width="126" Height="52" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <Grid Margin="34,28,34,28">

                    <Grid IsVisible="{Binding !IsLoggedIn}" MaxWidth="520" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Classes="formPanel" Padding="30" MinWidth="420" MaxWidth="520" HorizontalAlignment="Stretch">
                            <Grid>
                                <StackPanel Spacing="22" IsVisible="{Binding !IsResettingPassword}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="ДОСТУП К ЛАУНЧЕРУ" Classes="microLabel"/>
                                        <TextBlock Text="Вход в аккаунт" Classes="formTitle"/>
                                        <TextBlock Text="Заполните данные ниже для входа или регистрации." Classes="captionText" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Spacing="10">
                                        <TextBlock Text="ИМЯ ИГРОКА" Classes="fieldLabel"/>
                                        <TextBox Text="{Binding Username}" Watermark="Введите ваше имя" Height="54" FontSize="15"/>
                                    </StackPanel>

                                    <StackPanel Spacing="10" IsVisible="{Binding IsRegistering}">
                                        <TextBlock Text="EMAIL" Classes="fieldLabel"/>
                                        <TextBox Text="{Binding Email}" Watermark="Введите email" Height="54" FontSize="15"/>
                                    </StackPanel>

                                    <StackPanel Spacing="10">
                                        <TextBlock Text="ПАРОЛЬ" Classes="fieldLabel"/>
                                        <TextBox Text="{Binding Password}" Watermark="Введите пароль" PasswordChar="●" Height="54" FontSize="15"/>
                                    </StackPanel>

                                    <Border Classes="errorCard" Padding="16,14" IsVisible="{Binding HasLoginError}">
                                        <TextBlock Text="{Binding LoginErrorMessage}" Foreground="#ff6a4a" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Center"/>
                                    </Border>

                                    <StackPanel Spacing="12">
                                        <Button Content="ВОЙТИ" Command="{Binding LoginCommand}" Classes="primaryButton" Height="58" IsVisible="{Binding !IsRegistering}"/>
                                        <Button Content="СОЗДАТЬ АККАУНТ" Command="{Binding RegisterCommand}" Classes="primaryButton" Height="58" IsVisible="{Binding IsRegistering}"/>
                                    </StackPanel>

                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                        <Button Grid.Column="0" Content="НЕТ АККАУНТА? РЕГИСТРАЦИЯ" Command="{Binding ToggleRegisterCommand}" Classes="secondaryButton" Height="50"/>
                                        <Button Grid.Column="1" Content="ЗАБЫЛИ ПАРОЛЬ?" Command="{Binding ResetPasswordCommand}" Classes="ghostButton" Height="50"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Spacing="22" IsVisible="{Binding IsResettingPassword}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="ВОССТАНОВЛЕНИЕ ДОСТУПА" Classes="microLabel"/>
                                        <TextBlock Text="Сброс пароля" Classes="formTitle"/>
                                        <TextBlock Text="Укажите email и придумайте новый пароль." Classes="captionText" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Spacing="10">
                                        <TextBlock Text="EMAIL" Classes="fieldLabel"/>
                                        <TextBox Text="{Binding Email}" Watermark="Введите email" Height="54" FontSize="15"/>
                                    </StackPanel>

                                    <StackPanel Spacing="10">
                                        <TextBlock Text="НОВЫЙ ПАРОЛЬ" Classes="fieldLabel"/>
                                        <TextBox Text="{Binding NewPassword}" Watermark="Введите новый пароль" PasswordChar="●" Height="54" FontSize="15"/>
                                    </StackPanel>

                                    <Border Classes="errorCard" Padding="16,14" IsVisible="{Binding HasLoginError}">
                                        <TextBlock Text="{Binding LoginErrorMessage}" Foreground="#ff6a4a" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Center"/>
                                    </Border>

                                    <Button Content="СОХРАНИТЬ НОВЫЙ ПАРОЛЬ" Command="{Binding ConfirmResetPasswordCommand}" Classes="primaryButton" Height="58"/>
                                    <Button Content="← Назад к входу" Command="{Binding CancelResetCommand}" Classes="ghostButton" Height="48"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid IsVisible="{Binding IsLoggedIn}" ColumnDefinitions="1.08*,0.92*" ColumnSpacing="26" VerticalAlignment="Center" MaxWidth="1320" HorizontalAlignment="Center">
                        <Border Grid.Column="0" Classes="heroPanel" Padding="34">
                            <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="18">
                                <Border Width="164" Height="164" CornerRadius="38" Classes="logoShell" HorizontalAlignment="Left">
                                    <Border.Background>
                                        <ImageBrush Source="/Assets/Images/logo.png" Stretch="Uniform"/>
                                    </Border.Background>
                                </Border>

                                <StackPanel Grid.Row="1" Spacing="8">
                                    <TextBlock Text="SRP-RP" Classes="heroTitle"/>
                                    <TextBlock Text="POST-APOCALYPSE RESIDENT RP" Classes="sectionLead"/>
                                    <TextBlock Text="{Binding ModpackVersion}" Classes="versionBadge"/>

                                    <!-- Статус сервера -->
                                    <Border Background="#1a1410" CornerRadius="8" Padding="12,8" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding ServerStatusText}" FontSize="15" FontWeight="SemiBold" Foreground="{Binding ServerStatusColor}"/>
                                    </Border>
                                </StackPanel>

                                <TextBlock Grid.Row="2" Text="{Binding AboutProjectText}" Classes="bodyText" TextWrapping="Wrap" MaxWidth="580"/>

                                <Grid Grid.Row="3" ColumnDefinitions="*" ColumnSpacing="14" Margin="0,10,0,0">
                                    <Border Grid.Column="0" Classes="infoCard" Padding="18">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="О ПРОЕКТЕ" Classes="microLabel"/>
                                            <TextBlock Text="SRP-RP Launcher" FontSize="20" FontWeight="Bold"/>
                                            <TextBlock Text="Официальный лаунчер для подключения к серверу. Автоматическая установка модов, обновлений и управление профилем." Classes="captionText" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="18" MinWidth="420" MaxWidth="520">
                            <Border Classes="formPanel" Padding="26">
                                <StackPanel Spacing="14">
                                    <TextBlock Text="ДЕЙСТВИЯ" Classes="microLabel"/>
                                    <TextBlock Text="Управление сборкой" Classes="formTitle"/>

                                    <Button Content="🎮 ИГРАТЬ" Command="{Binding LaunchCommand}" IsVisible="{Binding IsInstalled}" Classes="launchButton" Height="76" FontSize="24"/>
                                    <Button Content="📥 УСТАНОВИТЬ" Command="{Binding InstallCommand}" IsVisible="{Binding !IsInstalled}" Classes="primaryButton" Height="58" FontSize="18"/>
                                    <Button Content="🔍 ПРОВЕРИТЬ ФАЙЛЫ" Command="{Binding InstallCommand}" IsVisible="{Binding IsInstalled}" Classes="secondaryButton" Height="56" FontSize="16"/>
                                    <Button Content="🔄 ОБНОВИТЬ СБОРКУ" Command="{Binding UpdateModpackCommand}" IsVisible="{Binding IsInstalled}" Classes="secondaryButton" Height="56" FontSize="16"/>
                                    <Button Content="📁 ВЫБРАТЬ ПАПКУ" Click="ChooseFolderButton_Click" Classes="ghostButton" Height="54" FontSize="15"/>
                                </StackPanel>
                            </Border>

                            <Border Classes="statusPanel" Padding="24" IsVisible="{Binding StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <StackPanel Spacing="14">
                                    <TextBlock Text="СОСТОЯНИЕ ЛАУНЧЕРА" Classes="microLabel"/>
                                    <TextBlock Text="{Binding StatusMessage}" Classes="statusText" TextWrapping="Wrap"/>
                                    <ProgressBar Value="{Binding ProgressValue}" Maximum="100" Height="12" IsVisible="{Binding ProgressValue, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </ScrollViewer>

            <Border Grid.Row="2" Padding="30,18" Classes="chromePanel">
                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="18">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="SRP-RP Launcher" FontSize="13" FontWeight="Bold" Foreground="#ffb267"/>
                        <TextBlock Text="v1.0" Classes="captionText"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="Forge 1.20.1" Classes="captionText" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="2" Text="Создано для SRP-RP проекта • 2026" Classes="captionText" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <Border IsVisible="{Binding IsGameRunning}" Background="#E80B0705">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Padding="42" CornerRadius="24" Classes="overlayPanel" MinWidth="420" MaxWidth="520">
                <StackPanel Spacing="18">
                    <TextBlock Text="🎮 ИГРА ЗАПУЩЕНА" Classes="overlayTitle" HorizontalAlignment="Center"/>
                    <TextBlock Text="Лаунчер можно свернуть или закрыть. Игровой процесс уже запущен." Classes="bodyText" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" MaxWidth="360"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
