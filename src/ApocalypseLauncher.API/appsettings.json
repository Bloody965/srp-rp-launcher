{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=/app/data/apocalypse_launcher.db"
  },
  "Jwt": {
    "SecretKey": "CHANGE_THIS_TO_RANDOM_64_CHARACTERS_STRING_FOR_PRODUCTION",
    "Issuer": "ApocalypseLauncher.API",
    "Audience": "ApocalypseLauncher.Client",
    "ExpirationHours": "24"
  },
  "Resend": {
    "ApiKey": "YOUR_RESEND_API_KEY_HERE",
    "FromEmail": "onboarding@resend.dev",
    "FromName": "SRP-RP Launcher"
  },
  "Modpack": {
    "RequireWhitelist": false,
    "StoragePath": "/app/modpacks"
  }
}
