# Скопируйте в Railway → Service (API) → Variables (каждая строка = отдельная переменная, формат KEY=VALUE).
# Не коммитьте файл с реальными секретами.

# Обязательно в Production (64+ символов лучше). Сгенерировать: pwsh scripts/New-JwtSecret.ps1
Jwt__SecretKey=

# После добавления PostgreSQL в проект — в Variables сервиса API нажмите "Reference" → DATABASE_URL от базы.
# Или Railway сам пробросит, если связали сервисы.

# HTTPS-оригин статического сайта (без пути). Достаточно одного из вариантов:
Cors__AllowedOrigins__0=
# или одна переменная (подхватывается API как CORS origin):
# SITE_PUBLIC_ORIGIN=https://username.github.io

# Только если ещё нет URL сайта и нужно срочно проверить вход с localhost / временного хоста:
# CORS_ALLOW_ANY_ORIGIN=true

# Лаунчер на ПК игрока (не Railway): переопределить URL API без пересборки
# SRP_API_BASE_URL=https://srp-rp-launcher-production.up.railway.app

# Опционально — IP:порт Minecraft (для ответов API)
# MinecraftServer__Address=
# MinecraftServer__Port=
